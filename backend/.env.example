# --- Supabase Postgres (Session mode / direct) ---
# Supabase "Connection string" (URI): lim inn som DATABASE_URL (kun i Render secrets / lokal .env — ikke commit).
# postgres:// og postgresql:// blir automatisk til postgresql+psycopg2://
# Passord med ?, &, @ osv. må URL-kodes (%3F, %26, %40) i selve URL-en.
DATABASE_URL=postgresql+psycopg2://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres
# Kun hvis URL ikke allerede har ?sslmode=require:
# DATABASE_SSLMODE=require

# --- CORS: inkluder Vercel-produksjon og evt. preview (*.vercel.app) ---
CORS_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# --- Lagring: local (disk) eller r2 (Cloudflare R2) ---
STORAGE_BACKEND=r2
R2_ACCOUNT_ID=
R2_BUCKET_NAME=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# S3-kompatibel endpoint (R2 dashboard). Enten R2_ENDPOINT eller R2_ENDPOINT_URL:
# R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com

# Lokale mapper (YOLO-eksport/trening + fallback når STORAGE_BACKEND=local)
UPLOAD_DIR=./data/uploads
EVIDENCE_DIR=./data/evidence
YOLO_DATASET_EXPORT_DIR=./data/yolo_dataset
YOLO_TRAIN_OUTPUT_DIR=./data/yolo_runs

YOLO_MODEL_PATH=./data/models/yolov8s.pt

# Øvrig (se tidligere mal)
# OPENAI_API_KEY=
# SCANNER_API_TOKEN=
