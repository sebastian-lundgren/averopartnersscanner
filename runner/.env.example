SCANNER_API_BASE=http://127.0.0.1:8000
# SCANNER_API_TOKEN=sett-samme-som-backend-SCANNER_API_TOKEN
# Relativt til repo-rot (anbefalt når runner startes med cwd=prosjektrot). Legacy ../backend/... tolkes fra runner/.
YOLO_MODEL_PATH=backend/data/models/yolov8s.pt
SCAN_MAX_ATTEMPTS=4
# standard_front = Google Maps SV; venstre/høyre = egne nabopanoer (m-liste vinkelrett), ikke samme-pano-rotasjon. SCAN_MAX_ATTEMPTS>=3 gir alle tre når plan tillater.
# FRONT_NEIGHBOR_STEP_TRIES_M=7,9.5,12
STREETVIEW_WAIT_MS=4500
STREETVIEW_WAIT_QUICK_MS=2750
# STREETVIEW_POST_READY_MS_FIRST=1600
# STREETVIEW_POST_READY_MS_NEXT=1180
# CAPTURE_PRE_STABILIZE_MS=700
# CAPTURE_PRE_STABILIZE_MS_NEXT=640
# CAPTURE_STABILIZE_MS=800
# FOCUS_PRE_CLICK_MS=120
PLAYWRIGHT_HEADLESS=false
YOLO_CONF_STRONG=0.65
YOLO_CONF_FLOOR=0.25
# YOLO_CONF_WEAK=0.35
